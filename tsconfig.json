{
    "compilerOptions": {
        "noImplicitReturns": true,
        "removeComments": true,
        "declaration": true,
		    "skipLibCheck": true,
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "exactOptionalPropertyTypes": true,
        "forceConsistentCasingInFileNames": true,
        "target": "es2022",
        "lib": [
            "es2022"
        ],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "outDir": "dist",
    },
    "include": [
        "src/**/*.ts",
    ],
    "exclude": []
}
